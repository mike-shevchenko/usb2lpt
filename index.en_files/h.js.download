// Common style support for ~heha web pages
// This script should run on any browser (to be checked)
// The web pages using this script should also have these (optional) header content:

// <meta charset="utf-8">
//	Page must be UTF-8 encoded

// <meta name=date content="1996-01-23">
//	This is the _creation_ date, for the footer

// <meta name=resp content="Name, Phone">
//	This is the _responsible person_ for this topic (machine), for the footer

// <link rel=frameset href="Index.htm">
// 	When this page is normally a part of a frameset,
//	let the user choose to jump to it or not (no annoying automatic redirection)

// <link rel=alternate href="index.de.htm">
//	Available language versions of this page;
//	the top-left language selection bar will be populated

// <link rel=next href="../Piezomess/">
//	The next recommended page for linear navigation,
//	the bottom-right navigation bar will be populated
//	Firefox preloads that page.

// <link rel=prev href="../hs/">
// <link rel=up href="../software/">
//	Other relations. If "up" is not given, "." is used for files and ".." for directories.

// <link rel=stylesheet href="h.css">
//	Formatting relies on that style sheet

// Damit's mit IE11 läuft dürfen keine Pfeilfunktionen verwendet werden,
// selbst dann nicht, wenn der Kode niemals unter IE11 ausgeführt wird:
// Der Syntaxprüfer verweigert die Ausführung des JavaScripts.
// Außerdem kein "let" und "const"

"use strict";

// 0. Für ältere Browser HTML5-Tags schaffen — sowie 5 eigene Tags
(function(){
 var tags=['header','hgroup','nav','article','figure','figcaption',
	'section','aside','footer','sqrt','o','blink','resp','line','sevenseg'];
 for (var i=0; i<tags.length; i++) document.createElement(tags[i]);
 if (!document.head) document.head=document.getElementsByTagName("head")[0]; // Firefox 3.6
})();

// Show a link to content frame if not in a frameset
// For use at top of document
function info(link,text) {
if (top == self)
  document.writeln("<a href='"+link+"' target=_top>"+text+"</a>");
}

// Global variable for language detection
var lang;

// External link, show an icon, and open in a new window?
function e_de(url,text) {
 document.write("<IMG src='icons/extern.gif' align=top alt=''> <a href='"+url+"'>"+text+"</a>");
}

function E_de(url,tip,text) {
 document.write("<IMG src='icons/extern.gif' align=top alt=''> <a href='"+url+"' title='"+tip+"'>"+text+"</a>");
}

function strDateFormat(y,m,d) {
 y=parseInt(y,10);
 m=parseInt(m,10);	// 1..12, nicht 0..11
 d=parseInt(d,10);	// führende Nullen entfernen
 var was=new Date(y,m-1,d);
 var now=new Date();
 var s,today=new Array;
 switch (lang) {
  case "en": {
   var mo=["January","February","March","April","May","June","July","August","September","October","November","December"];
   s=mo[m-1]+" "+d+". "+y;
   today=new Array("today","yesterday");
  }break;
  case "jp": {
   s=y+"年"+m+"月"+d+"日";
   today=new Array("今日","昨日","一昨日");	// kyô, kinô, ototoi
  }break;
  case "cn": {
   s=y+"年"+m+"月"+d+"日";
   today=new Array("今天","昨天","前天");
  }break;
  case null:
  case "de": {
   var mo=["Januar","Februar","März","April","Mai","Juni","Juli","August","September","Oktober","November","Dezember"];
   s=d+". "+mo[m-1]+" "+y;
   today=new Array("heute","gestern","vorgestern");
  }break;
  default: s=was.toLocaleDateString(undefined,{year:'numeric',month:'long',day:'numeric'});
 }
 var age=Math.floor((now.getTime()-was.getTime())/(1000*60*60*24));	// Alter in Tagen
 if (0<=age && age<today.length) s="<b>"+today[age]+"</b>";
 var dt=y+"-"+('0'+m).substr(-2)+"-"+('0'+d).substr(-2);
 return "<time datetime=\""+dt+"\">"+s+"</time>";
}

// generiert String: "erstellt: <Datum>"
function erstellt(creat) {
 var s=_tr("erstellt")+": ";
 switch (typeof(creat)) {
  case "string": s+=strDateFormat(creat.substr(0,4),creat.substr(5,2),creat.substr(8,2)); break;
  case "number": s+=strDateFormat((Math.floor(creat/10000)+2000),Math.floor(creat/100)%100,creat%100); break;
 }
 return s;
}

// <creat> in der Form yymmdd (Zahl) oder "yyyy-mm-dd" (String)
function address(creat) {
 var s="<p id=date><a href='email?"+document.title+"'>Henrik Haftmann</a>, ";
 s+=erstellt(creat)+" — ";
 var time=document.lastModified;	// in der Form "mm/dd/yyyy HH:MM:SS"
 s+=_tr("mdate")+": "+strDateFormat(time.substr(6,4),time.substr(0,2),time.substr(3,2));
 return s;
}

function switchBild(el,url,width,className) {
// el muss parentNode haben!
 switch (el.nodeName) {
  case "OBJECT":
  if (!url.match(/svg$/i)) el=g_object_img(el,url);
  else el.data=url;
  break;
  case "IFRAME":
  if (!url.match(/svg$/i)) el=g_object_img(el,url);
  else el.src=url;
  break;
  case "DIV":
  if (!url.match(/(stl|wrl)$/i)) el=g_object_img(el,url);
  else g_stlviews.get(el.parentNode).loadurl(url);
  return;	// "width" nicht ändern
  default:
  el.src=url;
  el.className=className;
 }
 if (width) el.width=width;
 else el.removeAttribute("width");
}

var g_onimgerror;	// Funktionszeiger
var g_object_img;	// Funktionszeiger
var g_stlloads=new Array;	// Für verzögerte Aufrufe von stlload()
var g_stlviews=new WeakMap();	// Um bei geladenen stlview()-Closures STLs zu wechseln
// Umformen von <ul><li><a href=bildname.ext>text</a>...</ul>
// in <div><img src=erstesbild.ext><fieldset><input...></fieldset></div>
function MultiBild(figs) {
 for (var BildNr=0;BildNr<figs.length;BildNr++) (function(fig,BildNr){	// Capture erstellen
  var ul=fig.getElementsByTagName("ul");
  if (ul && ul.length) try{
   ul=ul[0];
   var img=createEl("img");
//   img.setAttribute("id","B"+BildNr);
//   img.onerror=g_onimgerror;	// TODO: Nicht global
   var div=createEl("div",{"class":"multi"},[img]);	// <figure> als Flexbox: Hier Problem mit <figcaption>
   var pic1=null;
   var fieldset=createEl("fieldset",{"class":"box",title:_tr("selbild")});
//    s+="<fieldset class='box' title=\""++"\">\n";	// eine Box beginnt mit jenem <ul>
   var subttl=ul.innerHTML;
   var e=subttl.toLowerCase().indexOf("<li");	// Untertitel einfügen wenn etwas zwischen <ul> und <li>
   subttl=subttl.substr(0,e);
   if (subttl.search(/[!-z]/)>=0) {
    var legend=createEl("legend");
    legend.innerHTML=subttl;
    fieldset.appendChild(legend);
   }
   var lis=ul.getElementsByTagName("LI");
   for (var i=0; i<lis.length; i++) (function(li,i){
    var a=li.getElementsByTagName("A")[0];	// MUSS ein <a>-Tag enthalten!
    if (!a) return;
    if (i) fieldset.appendChild(createEl("br"));
    var id=getUniqueId();	// muss uniq sein damit die "for"-Bezüge der Labels funktionieren
    var src=a.href;		// Dadurch dass "src" in einer umgebenden Funktion steckt ist der Inhalt bei onClick für jedes Bild einzeln verfügbar (= Closure)
    var width=a.getAttribute("width");	// dasselbe für „width“
    var className=a.className;
    var input=createEl("input",{type:"radio",name:"B"+BildNr,id:id});
    input.onclick=function(e) {switchBild(div.firstChild,src,width,className);}
    if (!pic1 && src) {
     input.checked="checked";
     img.setAttribute("src",pic1=src);
     if (width) img.setAttribute("width",width);
// Achtung! Durch Setzen von src kann img via img.onerror verwaisen, wir holen uns das neue img vom div und überlassen das alte der Müllabfuhr
     img=div.firstChild;
     if (a.className) img.className=a.className;
    }
    fieldset.appendChild(input);
    var title=a.innerHTML;	// auch mit HTML-Formatierungen
    if (!title) {
     var a=src.lastIndexOf("/")+1;	// Bild-Dateiname
     var e=src.lastIndexOf(".");	// … ohne Endung
     title=unescape(src.substring(a,e));
    }
    var label=createEl("label",{"for":id});
    label.innerHTML=title;
    fieldset.appendChild(label);
    var rest=li.innerHTML;
    var e=rest.toLowerCase().indexOf("</a>");
    rest=rest.substr(e+4);
    if (rest) fieldset.appendChild(createEl("small")).innerHTML = rest;
   })(lis[i],i);

//   var divr=document.createElement("div");
//   divr.className="bggray02";
//   divr.style="display:inline-block";	// für den Fall dass display:flex im alten Browser nicht zur Verfügung steht, gleiches Verhalten simulieren

   div.appendChild(fieldset);

   fig.replaceChild(div,ul);
   
/* alter Mist
   var table=document.createElement("table");
   p.replaceChild(table,uls[0]);
   table.cellspacing=0;
   table.cellpadding=4;
   table.align="center";
   <tr><td>td

   var t="<img src='"+pic1+"' id=B"+BildNr;
   if (class1) t+=" class='"+class1+"'";
   t+=" onerror='g_onimgerror(this)'";
   t+="><div class=bggray02 style=display:inline-block>"+s;
//   table.innerHTML=t;
   p.innerHTML=t
*/
//   for (var h=1; h<uls.length; h++) p.removeChild(uls[h]);
  }catch(e){		// keine Image-Liste: Nichts tun!
   console.log("MultiBild versagt");
  }
 })(figs[BildNr],BildNr);
}

function appendUrlLastElem(s,url) {
 if (url) {
  if (url.lastIndexOf('/') == url.length-1) url=url.substr(0,url.length-1);
  url=url.substr(url.lastIndexOf('/')+1);
  if (url) s+=" ("+decodeURI(url)+")";	// keine Namensausgabe fürs Wurzelverzeichnis
 }
 return s;
}

String.prototype.format=function() {
 var a = this;
 if (a) for (var k in arguments) a = a.replace("{" + k + "}", arguments[k]);
 return a;
}

