// Hilfsfunktionen (Canvas)
function line(dc,x,y,xe,ye) {
 dc.beginPath();
 dc.moveTo(x,y);
 dc.lineTo(xe,ye);
 dc.stroke();
}
function circle(dc,x,y,r) {
 dc.beginPath()
 dc.arc(x,y,r,0,2*Math.PI,false);	// Firefox 3.6 benötigt 6. Argument (false)
 dc.stroke();
}

// Tooltips mit HTML-Inhalt: Verweis mit Attribut "tip=#label",
// der Tip in <tip id=label>Inhalt</tip> irgendwo im Dokument,
// oder Inhalt mit Attribut "tip=content",
// Vor allem für komfortable Eagle-Tooltips interessant,
// aber derzeit enthält der <description>-Text „escapte“ HTML-Sequenzen,
// die noch nicht in HTML umgesetzt werden

function htmlTooltips(root) {
 try{	// IE8 kann kein CSS3 in QuerySelectorAll: Ignorieren
  var x=document.querySelectorAll("tip:not([id])");
  for (var i=0; i<x.length; i++) {
   x[i].parentNode.setAttribute("tip","");
  }
 }catch(err){}
 var tips=root.querySelectorAll("[tip]");
 for (var i=0; i<tips.length; i++) {
  tips[i].addEventListener("mouseover",function(e) {
   var tip=e.target;
   var to=setTimeout(function() {
    var val=tip.getAttribute("tip");
    var box;
    if (val=="") box=tip.querySelector("tip");
    else if (val.charAt(0)=='#') box=root.querySelector(val);
    else{	// tip-Attribut leeren und <tip> unterhalb anordnen
     box=root.createElement("tip");
     box.innerHTML=val;	// Inhalt umsetzen
     e.target.appendChild(box);
     e.target.setAttribute("tip","");
    }
    box.style.display="block";
    box.style.left=e.pageX+"px";
    box.style.top=e.pageY+20+"px";
    e.target.addEventListener("mouseout",function(e) {
     box.style.display="none";
    },false);
   },200);
   tip.addEventListener("mouseout",function() {
    clearTimeout(to);
   },false);
  },false);
 }
}

/* SortTable.js ab hier eingefügt sowie angepasst: deutsche Zahlen, strict-Modus
   TODO: Nach Spalten sortieren */
var sorttable = {
 init: function() {
  var tables=document.querySelectorAll("table.sortable");
  for (var i=0;i<tables.length;i++) this.makeSortable(tables[i]);
 },
 sortFunction: function(table,th,noreverse) {
  if (!noreverse && th.className.search(/\b(sorted|reversed)\b/) != -1) {
    // if we're already sorted by this column, just
    // reverse the table, which is quicker
   this.reverse(table);
  }else{
// build an array to sort. This is a Schwartzian transform thing,
// i.e., we "decorate" each row with the actual sort key,
// sort based on the sort keys, and then put the rows back in order
// which is a lot faster because you only do getInnerText once per row
   var a = [];
   var tb = table.tBodies[0];
   var rows = tb.rows;
   var col=th.columnindex;
   for (var j=0; j<rows.length; j++) {
    var tag=this.getCellText(rows,col,j);
    var dir=this.getDirCheck(rows,j);
    a[j]={dir:dir,tag:tag,row:rows[j]};
   }
   this.sort(a,th.sortfunction);
   for (var j=0; j<a.length; j++) tb.appendChild(a[j].row);	// sortiert DOM um
   this.checkSort(table);
  }
  this.group(table);
 },
// Prüft ob Tabellenzeile ein Verzeichnis ist, das voran sortiert werden soll
 getDirCheck: function(rows,y) {
  var dir=document.getElementById("dir_first");
  return dir && dir.checked && this.getCellText(rows,this.filenamecolumn,y).substr(-1)=="/";
 },	 
// Prüft die Tabelle auf (bereits) sortierte Spalten
 checkSort: function(table) {
  var h=table.headRow.cells;
  var rows=table.tBodies[0].rows;
  for (var i=0;i<h.length;i++) if (h[i].sortfunction) {	// Über alle Spalten …
   var th=h[i];		// remove class entry:
   th.className=th.className.replace(/\b(sorted|reversed)\b/,'');
   if (rows.length>1) {		// Nicht bei 0 oder 1 Datenzeilen
    var up=true;		// gucken ob aufwärts sortiert
    var dn=true;		// gucken ob abwärts sortiert
    var key=this.getCellText(rows,th.columnindex,0);	// Erste Datenzeile
    var dir=this.getDirCheck(rows,0);
    for (var j=1; j<rows.length; j++) {
     var nkey=this.getCellText(rows,th.columnindex,j);
     var ndir=this.getDirCheck(rows,j);
     var diff=dir-ndir;
     if (!diff) diff=th.sortfunction(nkey,key);
     if (!(diff>=0)) up=false;	// Nicht (mehr) aufwärts
     if (!(diff<=0)) dn=false;	// Nicht (mehr) abwärts
     if (!up&&!dn) break;	// Weitervergleichen sinnlos
     key=nkey;			// für nächste Runde
     dir=ndir;
    }
    if (up) th.className+=' sorted';	// Wenn beides dann auch "sorted"
    else if (dn) th.className+=' reversed';
   }
  }
 },
 group: function(table) {	// Gruppierungs-Trennstriche erzeugen bzw. wegnehmen
  var x,gd;
  for (x=0; x<table.headRow.cells.length; x++) {
   var th=table.headRow.cells[x];
   if (th.className.match(/\b(sorted|reversed)\b/)) {
    gd=th.getAttribute("data-group");	// Entweder eine Zahl ("alle xx Zeilen") oder ein regulärer Ausdruck
    break;
   }
  }
  var a0;
  for (var y=0; y<table.tBodies[0].rows.length; y++) {
   var tr=table.tBodies[0].rows[y];
   tr.className=tr.className.replace(/\bendgroup\b/,'');
   if (gd			// Gruppendefinition vorhanden?
   && y+1!=table.tBodies[0].rows.length) {	// Nicht-letzte Zeile?
    if (parseInt(gd)==gd) {	// Numerisch? (Alle xx Zeilen gruppieren)
     if (y%gd==gd-1) tr.className+=" endgroup";
    }else{
     var s1=this.getCellText(table.tBodies[0].rows,x,y+1);	// Text der Folgezeile
     var a1=s1.match(gd);	// Nach regulärem Ausdruck gruppieren
//     console.log(s1,a1,gd);
     if (a1 && a0 && a1[1]!=a0[1]
     || a1 && !a0		// Wechsel der Gültigkeit
     || !a1 && a0) tr.className+=" endgroup";
     a0=a1;
    }
   }
  }
 },
 makeSortable: function(table) {
  table.headRow = table.getElementsByTagName('thead')[0].rows[0];
  table.headRow.title=_tr("sort");
  if (table.className.match(/\bfilelist\b/)) {
// prepend such a table with a “directories first” checkmark if it contains directories.
// The file name column has to be the one with "colspan=2",
// and directory names have to end with slash.
   var b=table.tBodies[0];
   if (!b) return;
   var r=b.rows;
   var c=r[0].cells;
   for (var i=0; i<c.length; i++) {
    if (c[i].colSpan==2) {
     this.filenamecolumn=i;	// tack this “attribute” to this object
     break;
    }
   }
   if (this.filenamecolumn>=0) {	// Found leftmost column for file names.
    for (var j=0; j<r.length; j++) {
     var c=r[j].cells[this.filenamecolumn];
     var t=c.textContent;
     if (!t) t=c.innerText;
     if (t.substr(-1)=='/') {
	// Found one name with "/" at end, so create the necessary checkbox and exit loop
      var n=createEl("input",{id:"dir_first",type:"checkbox"});
      //n.checked=true;
      var self=this;
      n.onchange=function(e) {
       var h=table.headRow.cells;
       var i;
       for (i=0; i<h.length; i++) 
	 if (h[i].className.match(/\b(sorted|reversed)\b/)) {	// find one sorted column
        self.sortFunction(table,h[i],true);
	break;
       }
      }
      table.parentNode.insertBefore(n,table);
      n=createEl("label",{"for":"dir_first"});
      if (n.textContent) n.textContent=_tr("dirfirst");
      else n.innerText=_tr("dirfirst");
      table.parentNode.insertBefore(n,table);
      break;
     }
    }
   }
  }
    // work through each column and calculate its type
  var ths = table.headRow.cells;	// Nur 1. Zeile!
  var j=0;
  for (var i=0; i<ths.length; i++) {
      // manually override the type with "class=sort_type"
   var override="";
   var th=ths[i];
   if (!th.className.match(/\bnosort\b/)) { // skip this col
    var mtch = th.className.match(/\b(sort_[a-z0-9]+)\b/);
    if (mtch) { override = mtch[1]; }
    if (override && typeof this[override] == 'function') {
     th.sortfunction = this[override];	// tack comparer function to head cell
    }else{
     th.sortfunction = this.guessType(table.tBodies[0].rows,j);
    }
	// make it clickable to sort
	//if (table.filenamecolumn>=0 && j>table.filenamecolumn) --j;
    th.columnindex = j;
    var self=this;
    th.onclick=function(e) {
     self.sortFunction(table,e.target);
    };
   }
   j+=th.colSpan;	// ".colSpan" gibt's anscheinend immer
  }
//  this.addSortkeys(table);
  this.checkSort(table);
  this.group(table);
 },
// Spalten mit dem Label "sorted" einen "sortkey" verpassen
/*
 addSortkeys: function(table) {
  var h=table.headRow.cells;
  var rows=table.tBodies[0].rows;
  for (var i=0;i<h.length;i++) if (h[i].className.match(/\bsorted\b/)) {
   var col=h[i].columnindex;
   for (var j=0;j<rows.length;j++) {	// TODO: colspan abzählen
    rows[j].cells[col].setAttribute("sortkey",j);
   }
   h[i].sortfunction=this.sort_numeric;
  }
 },
*/
 guessType: function(rows,col) {
    // guess the type of a column based on all non-blank rows
  for (var i=0; i<rows.length; i++) {
   var txt = this.getCellText(rows,col,i);
   if (txt) {
    if (txt.match(/^0\d/)) return this.sort_alpha;	// Telefonnummern
    if (!txt.match(/^[+-]?[\d,.]+/)) return this.sort_alpha;
   }
  }
  return this.sort_numeric;
 },
// Return file name extension (for “right side” of columns with colspan=2)
 ext: function(s) {		// Get file name extension (no "." at start)
  var i;			// 1. No dot == no extension (i == -1)
  var j=s.length;
  if (s.substr(j-1)=='/') s=s.substr(0,--j);	// remove trailing backslash and change length
  for (;;--j) {			// 2. Dot(s) at string end don't count
   i=s.lastIndexOf('.',j);	// 3. Only dot at start = no extension (i == 0)
   if (i<=0) break;		// dots only (..) or hidden filename with . at first
   if (i!=j-1) break;		// normal case, break "abc.exe" or "def.nix.." with i==3
  }
  return i>0?s.substr(i+1):"";	// deliver rest of string
 },
// Return text from table coordinate (x,y), checking for <colspan>.
// “Colspanned” coordinates return empty string, except for "filenamecolumn" columns.
// TODO: <rowspan> is not checked at all!
 getCellText:function(rows,x,y) {
  var i,j,n;
  if (this.filenamecolumn===x-1) return this.ext(this.getInnerText(rows[y].cells[x-1]));
  for (i=j=0; j<=x; i++) {
   n=rows[y].cells[i];
   if (!n) return "";		// im Fehlerfall
   j+=n.colSpan;
  }
  var t=this.getInnerText(n);
//  if (numeric && !n.getAttribute("sortkey")) {
//   n.setAttribute("sortkey",t);		// Attribut für nächste Sortierung setzen
//  }
  return t;
 },
 getInnerText: function(node) {
	// gets the text we want to use for sorting for a cell.
	// strips leading and trailing whitespace.
	// this is *not* a generic getInnerText function; it's special to sorttable.
	// for example, you can override the cell text with a customkey attribute.
	// it also gets .value for <input> fields.
  if (!node) return "";
  if (node.getAttribute) {
   var sortkey=node.getAttribute("sortkey");
   if (sortkey) return sortkey;
  }
  var hasInputs = (typeof node.getElementsByTagName == 'function') &&
                 node.getElementsByTagName('input').length;
  if (!hasInputs) {
   var txt=node.textContent;		// modern, schließt hidden ein
   if (!txt) txt=node.innerText;	// ohne hidden
   if (!txt) txt=node.text;		// ??
   if (txt) return txt.replace(/^\s+|\s+$/g,'');
  }
  switch (node.nodeType) {
   case 3:
   if (node.nodeName.toLowerCase() == 'input') {
    return node.value.replace(/^\s+|\s+$/g, '');
   }
   case 4: return node.nodeValue.replace(/^\s+|\s+$/g, '');
   case 1:
   case 11:
   var innerText = '';
   for (var i = 0; i < node.childNodes.length; i++) {
    innerText += this.getInnerText(node.childNodes[i]);
   }
   return innerText.replace(/^\s+|\s+$/g, '');
  }
  return '';
 },

 reverse: function(table) {	// reverse the rows in a table
  var tbody=table.tBodies[0];
  var i,j;
  for (j=0;j<tbody.rows.length;j++) if (!this.getDirCheck(tbody.rows,j)) break;
// 0. Verzeichnis-Zeilen tauschen, j = erste Zeile mit Datei
  for (i=j-2; i>=0; i--)  tbody.insertBefore(tbody.rows[i],tbody.rows[j]);
// 1. Zeilen vertauschen: Ab der vorletzten beginnend Zeile hinten anhängen
  for (i=tbody.rows.length-2; i>=j; i--) tbody.appendChild(tbody.rows[i]);
// 2. "sorted" gegen "reversed" in allen Tabellenspaltenköpfen tauschen
  var h = table.headRow.cells;
  for (i=0; i<h.length; i++) if (h[i].nodeType==1) {
   var hc=h[i].className;
   h[i].className = hc.search(/\bsorted\b/)!=-1
     ? hc.replace(/\bsorted\b/,'reversed')
     : hc.replace(/\breversed\b/,'sorted');
  }
 },
/* sort functions, each sort function takes two parameters, a and b */
 sort_int: function(a,b) {
  a=parseInt(a); if (isNaN(a)) a=1000000;
  b=parseInt(b); if (isNaN(b)) b=1000000;
  return a-b;
 },
 sort_numeric: function(a,b) {
  a=parseFloat(a.replace(',','.')); if (isNaN(a)) a=0;	// in Zahl umwandeln
  b=parseFloat(b.replace(',','.')); if (isNaN(b)) b=0;
  return a-b;
 },
 sort_alpha: function(a,b) {
  if (a=="" && b!="") return 1;
  if (a!="" && b=="") return -1;
  return a.localeCompare(b,undefined,{numeric:true,sensitivity:'base'});
 },
 sort: function(list,comp_func) {
// A _stable_ sort function to allow multi-level sorting of data thanks to Joseph Nahmias
// see: http://en.wikipedia.org/wiki/Cocktail_sort
  var b=0,t=list.length-1,swap=true,i;
  function swa() {		// local function capturing <i>, <list>, <comp_func> and <swap>
   if (!list[i].dir && list[i+1].dir || list[i].dir===list[i+1].dir && comp_func(list[i].tag,list[i+1].tag)>0) {
    var q=list[i];list[i]=list[i+1];list[i+1]=q;
    swap=true;
   }
  }
  while (swap) {
   swap=false;
   for (i=b; i<t; ++i) swa();
   t--;				// top element now sorted
   if (!swap) break;		// nothing swapped, i.e. all sorted
   for (i=t; --i>=b;) swa();
   b++;				// bottom element now sorted
  }
 }
}
