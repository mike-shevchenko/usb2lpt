function _tr(id) {
 var l=lang&&strings[lang]?lang:"de";
 var s=strings[l][id];		// Lokalisierte Version
 if (!s) s=strings.de[id];	// Deutsche Version
 if (!s) s=id;			// Irgendwas
 return s;
}

function strLinkText(rel,url) {
 if (!url) return;
 if (url.match(/\.(jpg|gif|png|bmp|svg)$/i)) rel+="pic";
 return appendUrlLastElem(_tr(rel),url);
}

/*****************
 * Popup-Fenster *
 *****************/
var clean_uri = location.protocol + "//" + location.host + location.pathname + location.hash;
// oh dieser Tipp ist fies: Man sieht so den angehängten Query-String nicht aber er scheint immer noch wirksam, oder nur für serverseitige Skripte?
// Zunächst nur Query-Strings entfernen
//Problem mit stlview!! window.history.replaceState({}, document.title, clean_uri);
// Lesezeichen anspringen mit #2 geht so nicht mehr! Offenbar springt der Browser <i>nach</i> dem Laden der Webseite
clean_uri = location.protocol + "//" + location.host + location.pathname;
// Deshalb passiert die Lesezeichen-Löschaktion erst nach 30 s mit der Entfernung der Abschattung
 
var pop = null;
var mouse = "mouse";	// "pointer" ab Firefox59, IE11, Chrome55

function popdown() {
  if (pop && !pop.closed) pop.close();
}

function popup(obj,w,h) {
  var url = obj.href;
  if (!url) return true;
  w = (w) ? w += 20 : 150;  // 150px*150px is the default size
  h = (h) ? h += 25 : 150;
  var args = 'width='+w+',height='+h+',sizeable';
  popdown();
  pop = window.open(url,'',args);
  return (pop) ? false : true;
}

if (window.addEventListener) {
 window.addEventListener("focus",popdown,false);
 window.addEventListener("unload",popdown,false);
}else{
 window.attachEvent("onfocus",popdown);
 window.attachEvent("onunload",popdown);
}

// Muss wiederholt aufgerufen werden, wenn sich entsprechende Listen ändern
// Lupenfunktion für Bilder (wie die üblichen Webshops)
function Lupe() {
 var imgs=document.querySelectorAll("img.tn");	// alle Bilder der Klasse "tn" (per CSS 48×48 Pixel klein)
 if (imgs.length) {		// sowie alle Bilder, die mittels "width" klein dargestellt werden
  var z=createEl("img",{"class":"tnh"});
  document.body.appendChild(z);
  for (var i=0; i<imgs.length; i++) {
   imgs[i].onmouseover=function(e) {
    function followMouse(e) {
     z.style.left=(e.clientX+10)+"px";
     z.style.top=(e.clientY+10)+"px";
    }
    z.src=this.src;			// gleiches Bild setzen
    z.style.display="block";
    followMouse(e);
    e.target.onmousemove=followMouse;	// nicht als Übergangs-Start
    e.target.onmouseout=function(e) {z.style.display="none";}
//      z.style.opacity=0;
//      window.setTimeout(function(e) {

//      },300);
//    },0);
   }
  }
 }
 document.querySelectorAll("img[width]")	// alle Bilder, die mittels "width" klein dargestellt werden
 .forEach(function(img) {
  img.style.cursor="zoom-in";	// "-webkit-zoom-in", "-moz-zoom-in", "url('/bilder/lupe.cur'), pointer"
  img.onclick=function(e) {
   location.href=e.target.src;
  };
// TODO: Panning bei mousemove innerhalb des Fensters (macht mehr Arbeit)
 });
}

/****************************************************************
 * Liefert für IE6 + IE7 querySelectorAll() nach (= „Polyfill“) *
 ****************************************************************/
if (!document.querySelectorAll) {
 document.querySelectorAll=function(selectors) {
  var style=document.createElement('style');
  document.documentElement.firstChild.appendChild(style);
  document._qsa = [];
  style.styleSheet.cssText=selectors+'{x-qsa:expression(document._qsa && document._qsa.push(this))}';
  window.scrollBy(0,0);
  style.parentNode.removeChild(style);
  var els=[];
  while (document._qsa.length) {
   var el=document._qsa.shift();
   el.style.removeAttribute('x-qsa');
   els.push(el);
  }
  document._qsa=null;
  return els;
 }
}
if (!document.querySelector) {
 document.querySelector=function(selectors) {
  var els = document.querySelectorAll(selectors);
  return (els.length) ? els[0] : null;
 }
}
if (!Array.prototype.forEach) {
 Array.prototype.forEach=function(callback,that) {
  var len=this.length>>>0;
  for (var i=0; i<len; i++) if (i in this) callback.call(that,this[i],i,this);
 };
}
if (!Array.prototype.map) {
 Array.prototype.map=function(callback,that) {
  var len=this.length>>>0, A=new Array(len);
  for (var i=0; i<len; i++) if (i in this) A[i]=callback.call(that,this[i],i,this);
  return A;
 };
}
if (!Array.prototype.filter) {
 Array.prototype.filter=function(callback,that) {
  var len=this.length>>>0, A=new Array(len), k=0;
  for (var i=0; i<len; i++) if (i in this && callback.call(that,this[i],i,this)) A[k++]=this[i];
  A.length=k;
  return A;
 };
}
if (!Array.prototype.every) {
 Array.prototype.every=function(callback,that) {
  var len=this.length>>>0;
  for (var i=0; i<len; i++) if (i in this && !callback.call(that,this[i],i,this)) return false;
  return true;
 };
}
if (!Array.prototype.findIndex) {
 Array.prototype.findIndex=function(callback,that) {
  var len=this.length>>>0;
  for (var i=0; i<len; i++) if (i in this && callback.call(that,this[i],i,this)) return i;
  return -1;
 };
}
if (!Array.prototype.find) {
 Array.prototype.find=function(callback,that) {
  var i=this.findIndex(callback,that);
  if (i>=0) return this[i];
 };
}
if (!Array.prototype.keys) {
 Array.prototype.keys=function() {
  var len=this.length>>>0, A=new Array(len);
  for (var i=0; i<len; i++) A[i]=i;
  return A;
 };
}
if (!Array.prototype.indexOf) {
 Array.prototype.indexOf=function(el,i) {
  var len=this.length>>>0;
  for (i=i|0; i<len; i++) if (i in this && this[i]===el) return i;
  return -1;
 };
}
if (window.NodeList && !NodeList.prototype.forEach)
  NodeList.prototype.forEach=Array.prototype.forEach;
if (window.HTMLCollection && !HTMLCollection.prototype.forEach)
  HTMLCollection.prototype.forEach=Array.prototype.forEach;

// HTML-Elementebaum „in einem Rutsch“ generieren, meist nur ein Element
function createEl(tag,attr,sub) {
 if (!sub) sub=[];
 if (!attr) attr={};
 var el=document.createElement(tag);
 for (var i in attr) {
  if (typeof attr[i]=="object") Object.assign(el[i],attr[i])	// für "style"
  else el.setAttribute(i,attr[i]);
 }
 for (var i=0; i<sub.length; i++) el.appendChild(sub[i]);
 return el;
}
// Dokumentweit eindeutige ID beschaffen, wird benötigt um <input> und <label> automatisiert zu verknüpfen
var uniqueId = 0;
function getUniqueId() {
 var s;
 do s = "UID"+(++uniqueId);
 while (document.getElementById(s));
 return s;
}
// Zuordnung Hotkey => Input-ID
var uniqueHotkeys = {};
// Hier: Zeichen die auf einer deutschen Tastatur erreichbar sind
var keysAvailable = /[0-9a-zäöüß,.+#-]/;
// Dokumentweit eindeutigen Hotkey finden
function getUniqueHotkey(s,id) {
 for (var i=0; i<s.length; i++) {
  var c = s.substr(i,1).toLowerCase();
  if (!keysAvailable.test(c)) continue;
  if (c in uniqueHotkeys) continue;
  uniqueHotkeys[c]=id;
  return [c,i];
 }
 return null;
}
// Ersten Textknoten mit lesbarem Text finden
// Geht auch mit XPath aber ich weiß nicht wie
function findTrueTextNode(n) {
 if (n.nodeName=="#text" && keysAvailable.test(n.nodeValue.toLowerCase())) return n;
 var ch = n.childNodes;
 for (var i=0; i<ch.length; i++) {
  var cn = findTrueTextNode(ch[i]);
  if (cn) return cn;
 }
 return null;
}
// String des Textknotens an Position i unterstreichen
function splitTextNode(tn,i) {
 var s = tn.nodeValue, s1 = s.substr(0,i), s2 = s.substr(i,1), s3 = s.substr(i+1);
 if (!s2) return;
 var par = tn.parentNode;
 if (s1) par.insertBefore(document.createTextNode(s1),tn);
 par.insertBefore(createEl("u",{"class":"gui"},[document.createTextNode(s2)]),tn);
 if (s3) par.insertBefore(document.createTextNode(s3),tn);
 par.removeChild(tn);
}
// Verbindet <input> mit benachbartem <label> mit eindeutigen IDs
// und weist AccessKeys zu
function joinLabelToInput() {
 var inputs = document.querySelectorAll("input");
 for (var i=0; i<inputs.length; i++) {
  var input = inputs[i];
  var label = input.nextElementSibling;
  if (!label || label.nodeName!="LABEL") label = input.previousElementSibling;
  if (!label || label.nodeName!="LABEL") return;
  var id = input.getAttribute("id");
  if (!id) {
   id = getUniqueId();
   input.setAttribute("id",id);
  }
  label.setAttribute("for",id);
  var tn = findTrueTextNode(label);
  if (tn) {
   var s = tn.nodeValue;
   var k = getUniqueHotkey(s,id);
   if (k) {
    input.setAttribute("accessKey",k[0]);
    splitTextNode(tn,k[1]);
   }
  }
 }
}
// Wurzelverzeichnis für das jeweilige Webangebot beschaffen
function getRoot() {
 let prefix=window.location.pathname.split('/')[1];	// Pfad zu root zusammenfrickeln
 if (prefix.substr(0,1)=='~') return '/'+prefix;	// "~heha" oder "~haftmann", je nach höherer Lehranstalt
 return "";
}

/********************************************************
 * Riesige Funktion, Aufruf nach dem Laden der Webseite *
 ********************************************************/
function onLoad() {
 var b=document.body;
 if ("onpointerdown" in b) mouse = "pointer";

// Lokale Funktionen

// Automatische Sections mit Header-IDs
// Generiert Eigen-Links (mit Schlusspunkt - zur Unterscheidung von Zeilennummern)
// Generiert Inhaltsverzeichnis an Node <content>
// Packt alles hinter der Überschrift in ein <span> zum Wegklicken
// REKURSIVE FUNKTION!
// TODO: Sollte <article> statt <section> erstellen, wenn es <meta>-Einträge gibt
// Routine hat Probleme bei nicht abgeschlossenen <i> (= kein sauberes HTML)
 function addSections(n,content,level) {
// Zur Detektion von Section-Footern (= alles nach dem letzten <hr>) [TODO: Section-weise]
// Testet ob <node> = <HR> ist UND ob danach kein H<level>..H5 und auch kein HR folgt.
  function isLastHr(node) {
   if (node.nodeName!="HR") return false;
   if (node.width) return false;				// gestalterisch
   for (var n=node.nextSibling;n;n=n.nextSibling) {
    if (n.nodeName.match("H[1-"+level+"]")) return true;	// nächste Überschrift darüber
    if (n.nodeName.match("H["+level+"-5R]")) return false;	// nächste Überschrift darunter
   }
   return true;
  }
  function isNextAside(node) {
   if (node.nodeName!="ASIDE") return false;
   for (var n=node.nextSibling;n;n=n.nextSibling) {
    if (n.nodeType!=1) continue;
    if (n && n.nodeName.match("H[1-"+level+"]")) return true;
    return false;
   }
  }
  var hs=n.getElementsByTagName("h"+level);	// all "h" nodes of level 2..5 (1 and 6 are reserved here)
  if (hs.length) {
   var ol=createEl("ol");
   content.appendChild(ol);
   for (var i=0;i<hs.length;i++) {
    if (hs.length>100) {
     console.log("Zu viele Iterationen!");
     debugger;
     break;
    }
    var h=hs[i];
    var li=createEl("li");
    ol.appendChild(li);
    var a=createEl("a");
    li.appendChild(a);
    var t=h.textContent;
    if (!t) t=h.innerText;
    t=t.replace(/\([^)]+\)/g,"");	// Text in Klammern entfernen
    a.appendChild(document.createTextNode(t));
    var alreadySection=h.parentNode.nodeName=="SECTION";
    var s=alreadySection ? h.parentNode : createEl("section");
    s.className="collapsed";
    if (h.id) {
     s.id=h.id;
     h.removeAttribute("id");		// Header-ID umsetzen zur Section-ID
    }else s.id=(level>2?n.parentNode.id+".":"")+(i+1);
    a.href="#"+s.id;
	// Hinter die Überschrift einen Anker zur eigenen umgebenden <section> setzen
    var a=createEl("a",{"class":"hl",href:"#"+s.id,title:_tr("selflink")},[document.createTextNode("⚓")]);
    // Link auf Anker generieren
    h.appendChild(a);	// wird tatsächlich hinter den Überschriftentext gesetzt
    var node=h.nextSibling;	// nachfolgendes Element merken
    var prev=h;
    do prev=prev.previousSibling;		// Suchen eines direkt vorlaufenden echten Tags
    while(prev && prev.nodeName.charAt(0)=="#");	// Text, Kommentar u.ä.
    if (!alreadySection) {
     if (prev && (prev.nodeName=="ASIDE" || prev.nodeName=="IMG")) {
      s.appendChild(prev);	// umhängen eines vorlaufenden <aside> in die <section>
     }
     h.parentNode.insertBefore(s,h);	// <section> vor <h> einfügen
     s.appendChild(h);		// einhängen
    }
    var div=document.createElement("span");
    h.onclick=function(e){
     var n=e.target.parentNode;	// umschaltbar wie in Wikipedia; sichtbar nur auf Mobilgerät
     if (n.classList && n.classList.toggle) n.classList.toggle("collapsed");
    };
    var nested=false;
    var metas=new Array;
    var count=0;
//    if (alreadySection) debugger;
    while (node && (alreadySection || !isLastHr(node) && !isNextAside(node))) {
     if (node==hs[i+1]) break;	// nächste gleichrangige Überschrift; [i+1] sollte immer gehen
     if (node.nodeName=="SECTION" && !nested) break;	// Folgebereich hat <section></section>
     if (node.nodeName=="H"+(level+1)) nested=true;
     var next=node.nextSibling;
     if (next==metas[0]) next=null;
     if (node.nodeName=="META" && !nested) metas[metas.length]=s.appendChild(node);
     else div.appendChild(node);	// alles hinter <h> wird "umgehängt"
     if (metas.length>9) {
      console.log("Zu viele Metas!");
      debugger;
      break;
     }
     if (++count>300) {
      console.log("Zu viele Iterationen!");
      debugger;
      break;
     }
     node=next;			//  (Ausnahme: Letztes <HR>)
    }
    s.appendChild(div);
    if (metas.length) {
     var f=document.createElement("footer");
     for (var k=0; k<metas.length; k++) {
      var meta=metas[k];
      var p=document.createElement("p");
      var html="";
      switch (meta.getAttribute("name")) {
       case "resp": p.className="invis-resp"; html=_tr("resp")+": "+meta.content; break;
       case "date": html=_tr("Section")+erstellt(meta.content); break;
      }
      p.innerHTML=html;
      f.appendChild(p);
     }
     s.appendChild(f);
    }
    if (level<5) addSections(div,li,level+1);
   }
  }
 }

 function getTarget(id) {
  var target=document.getElementById(id)
	||   document.querySelector("a[name='"+id+"']");
  if (!target) alert(_tr("notarget").format(id));
  return target;
 }

 function animateTarget(id) {
  var target=getTarget(id);
  if (target && target.animate) {
   target.animate({background:['yellow','initial']},1000);
  }
 }
 function grayoutNonTarget(id) {
  var target=getTarget(id);
  if (target) {
   function doWithNeighbors(el,fu) {
    var pa=el.parentNode;
    var cn=pa.childNodes;
    for (var i=0; i<cn.length; i++)
    if (cn[i]!=el) fu(cn[i]);
    if (pa!=b) doWithNeighbors(pa,fu);
   }
   var undo=[];
   function addshadow(el) {
    if (el.nodeType==1) {
     undo.push({el:el,tag:"class",val:el.className});
     if (el!=b) {
      undo.push({el:el,tag:"title",val:el.title});
      el.title=_tr("grayout");
     }
     el.classList.add("shadowed");
    }
   }
   function undoshadow(e) {
    for (var i=0; i<undo.length; i++) {
     var u=undo[i];
     if (u.val) u.el.setAttribute(u.tag,u.val);
     else u.el.removeAttribute(u.tag);
    }
// Auch das Lesezeichen in der URL-Zeile wegnehmen
    window.history.replaceState({}, document.title, clean_uri);
   }
   addshadow(b);
   undo.push({el:target,tag:"class",val:target.className});
   target.classList.add("hilited");
   doWithNeighbors(target,addshadow);
   b.addEventListener("click",undoshadow);
   setTimeout(undoshadow,30000);
  }
 }

 var collectedIDs=[];
// REKURSIVE FUNKTION!
 function BezugRichtung(node) {
  var href=clean_uri;
  if (node.id) collectedIDs[collectedIDs.length]=node.id;	// IDs sammeln
  if (node.nodeName=="A"
  && !node.className
  && node.href
  && node.href.substr(0,href.length+1)==href+"#") {
   var id=node.href.substr(href.length+1);
   var found=false;
   for (var i=0; i<collectedIDs.length; i++) {
    if (id==collectedIDs[i]) {found=true; break;}
   }
   node.className=found?"lb":"lf";	// "local link forward" oder "local link back"
   if (!node.title) node.title=_tr(found?"so":"su");
   var target=getTarget(id);
   if (target) {
    var previous=target.style.background;	// Problem: Für jedes Target extra, könnte sich hier überlappen
    node.onmouseenter=function(){target.style.background="yellow";};
    node.onmouseleave=function(){target.style.background=previous;};
   }
  }
  var nodes=node.childNodes;
  if (nodes && nodes.length) for (var i=0; i<nodes.length; i++) BezugRichtung(nodes[i]);
 }

// Alle Zahlen mit Einheit (1 Leerzeichen dazwischen) suchen
// und das Leerzeichen durch &nbsp; ersetzen, später mal durch ein dünnes Leerzeichen
// REKURSIVE FUNKTION!
 function ErsZahlEinheit(node) {
  var nodes=node.childNodes;
  if (nodes && nodes.length) for (var i=0; i<nodes.length; i++) ErsZahlEinheit(nodes[i]);
  else{
   var s=node.textContent;	// besser
   if (!s) s=node.innerText;	// beachtet versteckten Text nicht
   if (s) {
    var sn=s.replace(/(\b[0-9]+?) ([pnµm°kMGT]?[A-z%€ΩÅ][A-z]?\b)/g,"$1 $2");
    if (sn!=s) if (node.textContent) node.textContent=sn; else node.innerText=sn;
   }
  }
 }
 function Invis() {	// <span class=invis> unsichtbar machen
  var ns=document.querySelectorAll(".invis");	// <span>,<div> der Klasse "invis"
  for (var i=0; i<ns.length; i++) {
   var n=ns[i];
   var z=createEl("img",{title:"Hier klicken für Zusatzinformation"});
   (z.onclick=function(e){
    this.src="icons/"+(this.src.indexOf("plus")>=0?"minus":"plus")+".gif";
   }).call(z);
   n.parentNode.insertBefore(z,n);
   if (n.nodeName=="DIV") {
    n.parentNode.insertBefore(createEl("b",{},[document.createTextNode("Veraltet: ")]),z);
   }
  }
 }

 function startslidein(div,onBottom) {
  if (div.className=="slidein") return;	// während Animation ignorieren
  if (onBottom) {		// starten wenn Fenster heruntergescrollt oder ohne Scrollbars
   if (window.scrollY+window.innerHeight<b.offsetHeight) return;
  }
  b.style.overflowX="hidden";
  div.onanimationend=function() {b.style.overflowX="auto";}
  div.className="slidein";	// Zuweisung = Animation starten
 }

 function showContent(e) {
  var nav=document.getElementById("Nav");
  nav.style.visibility="visible"
  startslidein(nav);
  nav=document.getElementById("NavBar");
  nav.style.visibility="hidden"
 }

 function hideContent(e) {
  var nav=document.getElementById("Nav");
  nav.className="";		// falls Animation noch nicht abgeschlossen
  nav.style.visibility="hidden"
  nav=document.getElementById("NavBar");
  nav.style.visibility="visible"
 }
// href mit document.referrer vergleichen und ggf. durch history.back ersetzen
// Das hat IMHO den Vorteil der erleichterten Navigation
 function back_replace(href) {
  var link=createEl("a",{href:clean_uri+"/../"+href});
	// das <a>-Element normalisiert den Pfad
  if (link.href==document.referrer) href="javascript:history.back()";
//  else alert(link.href+"\n"+document.referrer);
  return href;
 }
 var vorher_mobil=undefined;
 function onSizeChange() {
  var mobil=window.matchMedia && window.matchMedia('(max-width: 599px)').matches;
  if (vorher_mobil!==mobil) {	// Nur beim Umschalten beharken
   vorher_mobil=mobil;
// Umsortier-Aktionen!
   var n=document.querySelectorAll(mobil?"aside+h2,aside+h3,aside+h4,aside+h5":"h2+aside,h3+aside,h4+aside,h5+aside");
   for (var i=0; i<n.length; i++) {
    n[i].parentNode.insertBefore(n[i],n[i].previousSibling);
   }
  }
  setupLongTables();
 }
// Von rechts lesbarer Tabellenkopf
 function setupLongTables() {
// Precalculate heights after page load (and after each page resize),
// not for each scroll event again
  function setupLongTable(tbl) {
   var thead=tbl.querySelector("thead");
   var tfoot=tbl.querySelector("tfoot");
   var tcapt=tbl.querySelector("caption");
// Now we have all constant data to capture into the scroll event handler
   function onScroll() {
    var size=tbl.getBoundingClientRect();
    var top=size.top+window.pageYOffset;
    var bottom=size.bottom+window.pageYOffset;
    var hhead=thead?thead.getBoundingClientRect().height:0;
    var hfoot=tfoot?tfoot.getBoundingClientRect().height:0;
    var hcapt=tcapt?tcapt.getBoundingClientRect().height:0;
    if (tcapt) {
     if (getComputedStyle(tcapt).captionSide.indexOf("bottom")>=0) bottom-=hcapt;
     else top+=hcapt;
    }
    var tfrst=tbl.querySelector("tbody>tr:first-child");
    var hfrst=tfrst?tfrst.getBoundingClientRect().height:0;
    var tlast=tbl.querySelector("tbody>tr:last-child");
    var hlast=tlast?tlast.getBoundingClientRect().height:0;
    var dY=window.pageYOffset;
    if (thead) {
     if (dY>top && dY<bottom) {
// Das hier generiert einen angenehmen Scroll-Out-Effekt beim Verlassen der Tabelle nach unten
      var ey=bottom-hfoot-hhead-hlast;	// Letzte sinnvolle Platzierung
      if (dY>ey) dY=ey;
// Firefox scheint 1px Korrektur zu benötigen (für Randbreite?)
      thead.style.transform="translate(0,"+(dY-top-1)+"px)";
     }else{
      thead.style.removeProperty("transform");	// keine Verschiebung
      if (!thead.style.length) thead.removeAttribute("style");
     }
    }
    if (tfoot) {
     var h=window.innerHeight;
     if (dY+h<bottom && dY<bottom) {
      dY+=h-bottom;
      var ay=top+hhead+hfrst+hfoot-bottom;	// negativ
      if (dY<ay) dY=ay;				// Scroll-Out-Effekt
      tfoot.style.transform="translate(0,"+(dY+1)+"px)";
     }else{
      tfoot.style.removeProperty("transform");	// keine Verschiebung
      if (!tfoot.style.length) tfoot.removeAttribute("style");
     }
    }
   };
   window.removeEventListener("scroll",onScroll);
   onScroll();	// vorher schon umplatzieren
   window.addEventListener("scroll",onScroll);	// Dann bei jedem Scrollen
  }
  var tbls=document.querySelectorAll("table.long");
  for (var k=0; k<tbls.length; k++) setupLongTable(tbls[k]);
 }
// Für Firefox würde es genügen, die Tabellenköpfe so zu belassen.
// Alle anderen Browser erfordern das Einkapseln des Inhalts von <th> und <td> in <span>.
// Also tun wir das hier für alle Browser.
 function makeCcwHeader() {
  var theads=document.querySelectorAll("thead.ccw");
  for (var k=0; k<theads.length; k++) {
   var ths=theads[k].querySelectorAll("th,td");
   for (var i=0; i<ths.length; i++) {
    var div=createEl("span");
    while (ths[i].firstChild) div.appendChild(ths[i].firstChild);
    ths[i].appendChild(div);
   }
  }
 }
// function ungefähr(a,b,c) {if (!c) c==1; return a-c<=b && b<=+a+ +c;}
 function makeSizeable(divs) {
  function createEcken(div) {	// Kapsel für "div" = Element das die Größe ändert
// Normalerweise würde man für moderne Browser nur "pointerdown" statt "mousedown" verwenden.
// Aber dann tauchen (auf dem Desktop) rätselhafte Propagation-Bugs auf!
// Daher hat es sich als vorteilhaft erwiesen, "pointerdown" nur dann einzusetzen, wenn es keine Maus gibt.
// Das ist mit Media-Queries möglich; beim Testen der Webseite und Umschalten auf Mobil-Emulation
// muss man allerdings die Webseite neu laden (^R).
// Die Edge-„Geräte“emulation versagt beim Resize von stlview-Canvas, bei Firefox klappt's.
// Ein echtes Smartfon steht gerade (220227) nicht zur Verfügung
//   var mouse=window.matchMedia && window.matchMedia("(any-hover: none)").matches ? "pointer" : "mouse";
   if (div.querySelector("div.resizer")) return;	// hat schon Resizer als Kind: Nichts (mehr) tun!
   if (div.nodeName!="DIV"
    && div.nodeName!="ASIDE") {	// <canvas>, <iframe> darf keine Kindelemente enthalten
    var cs=window.getComputedStyle(div);	// width/height/box-sizing übernehmen
    var st={};
    if (cs.width) {st.width=cs.width;}
    if (cs.height) {st.height=cs.height;}
    if (cs["box-sizing"]) {st["box-sizing"]=cs["box-sizing"]; /*div.style["box-sizing"]="border-box";*/}
    var d2=createEl("div",{"class":"sizeable","style":st});
    div.parentNode.insertBefore(d2,div);	// einhängen
    d2.appendChild(div);	// umhängen
    div.classList.remove("sizeable");
    div=d2;			// mit dem neuen "div" weitermachen
   }
   var sizeX,sizeY,mouseX,mouseY;	// Werte für Containergröße und Mausposition bei "mousedown"
   function createEcke(j) {		// Kapsel für "j" = Nummer der Ecke
    function onMouseDown(e) {
     e.preventDefault();		// stlview: Objekt reht (bei Touch) trotzdem mit!
     e.stopImmediatePropagation();	// stlview: Sonst Start/Stop Animation
     // Im Moment von MouseDown die DIV-Größe und die Mausposition einfangen (= echtes Capture)
     var sty=getComputedStyle(div);
     sizeX=parseFloat(sty.getPropertyValue("width"));
     sizeY=parseFloat(sty.getPropertyValue("height"));
     mouseX=e.pageX;
     mouseY=e.pageY;
     // Die Kindfenster müssen sich selbst per "resize"-Event um ihre Größenveränderung kümmern!
     function onMove(e) {
      e.preventDefault();		// stlview: Objekt reht (bei Touch) trotzdem mit!
      e.stopImmediatePropagation();	// stlview: Sonst dreht das 3D-Objekt mit
      if (!(e.buttons&1)) onMouseUp(e);	// wenn 'was schief geht
      var mulX=[-1, 0,+1, 0,-1,+1,-1,+1][j],
          mulY=[ 0,-1, 0,+1,-1,-1,+1,+1][j];
      var w = sizeX, dx = e.pageX - mouseX,
          h = sizeY, dy = e.pageY - mouseY;
      w+=dx*mulX;
      h+=dy*mulY;
      if (mulX) div.style.width = w+"px";	// bei rein vertikaler Größenänderung Prozentangabe beibehalten
      if (mulY) div.style.height = h+"px";	// bei rein horizontaler Größenänderung Prozentangabe beibehalten
// Obwohl es logisch wäre, dem <div> ein Resize zu schicken,
// kann sich in HTML vieles rundherum ändern, und alle die das interessiert
// hängen sich besser bei window.addEventListener("resize") ein.
// Responsive sizeable Canvase sollten dann selbst nachgucken,
// ob sie sich wirklich ändern, um unnötiges Neuzeichnen zu vermeiden.
      window.dispatchEvent(new UIEvent('resize'));
      return false;
     };
     function onMouseUp(e) {
      e.preventDefault();		// stlview: Objekt reht (bei Touch) trotzdem mit!
      e.stopImmediatePropagation();
      window.removeEventListener(mouse+"move",onMove,true);
      window.removeEventListener(mouse+"up",onMouseUp,true);
      window.removeEventListener("keydown",onMouseUp,true);
      return false;
     }
     window.addEventListener(mouse+"move",onMove,true);
     window.addEventListener(mouse+"up",onMouseUp,true);
     window.addEventListener("keydown",onMouseUp,true);	// Im Fall eines Fehlers mit Taste (typischerweise ESC) den Resize-Modus abbrechen
     return false;
    }
    var ecke=createEl("div",{"class":"resizer e"+j});	// generiert Mauspfeil und Positionierung via CSS
    ecke.addEventListener(mouse+"down",onMouseDown,true);
    div.appendChild(ecke);
   }
   for (var j=0; j<8; j++) createEcke(j);	// erst Kanten, dann Ecken, für den Mauspfeil
  }
  if (divs.length!==undefined) for (var i=0; i<divs.length; i++) createEcken(divs[i]);
  else createEcken(divs);
 }
 function addClassToElements(sel,classname) {
  for (var i=0;i<sel.length;i++) {
   if (sel[i].classList) sel[i].classList.add(classname);	// neue Methode
   else{
    var c=sel[i].className;
    if (c) c+=" "; else c="";
    c+=classname;
    sel[i].className=c;	// nur wenn className schreibbar
   }
  }
 }
// Steckverbinder (ol.sv) in Tabelle umwandeln
// und die Form als Inline-SVG-Grafik visualisieren
// Attribute bei <li> gehen verloren!
 function sv2table(sv) {
  var lis=sv.querySelectorAll("li");
  var H=13;	// Höhe einer Tabellenzeile
  var table=createEl("table",{"class":sv.className});
  var inner="<tr height=4>";	// Platzhalter-Zeile
  switch (sv.className) {
   case "sv SubD": if (lis.length%2!=1) break;	// SubD-Stecker oder -Buchse
    inner+="<td colspan=2>";	// Platzhalter
//    table.border="1";
    inner+="<td style='padding:0' rowspan="+(lis.length+3)+">";
    inner+="<svg width=50 height="+(H*lis.length+16)+">\n";
    inner+="<path d='M4 17a13,13 0 0 1 14.084,-11.818l17,5a13,13 0 0 1 9.916,11.818v"+(H*(lis.length-2)+2)+"a13,13 0 0 1 -9.916,11.818l-17,5a13,13 0 0 1 -14.084,-11.818z' fill='white' stroke='black' stroke-width='2'/>\n";
    for (var j=0;j<lis.length;j++) {
     if (lis[j].getAttribute("omit")===null)
     inner+="<circle cx='"+(j%2?34:16)+"' cy='"+(H*j+16)+"' r='5' fill='gold' stroke='black' stroke-width='1'/>\n";
    }
    inner+="</svg>\n";
    inner+="<td colspan=2 rowspan=2>";
    for (var r=0;r<lis.length+1;r++) {
     inner+="<tr height=13>";
     if (r%2==0) {
      var n=r/2;
      inner+="<td rowspan=2 class=tl>"+lis[n].innerHTML;
      inner+="<td rowspan=2 class=nl>"+(n+1);
     }
     if (r%2==1 && r!=lis.length) {
      var n=(r+lis.length)/2
      inner+="<td rowspan=2 class=nr>"+(n+1);
      inner+="<td rowspan=2 class=tr>"+lis[n].innerHTML+"\n";
     }else if (r==lis.length) {
      inner+="<td colspan=2 rowspan=2>\n";
     }
    }
    inner+="<tr height=4><td colspan=2>\n";
   break;

   case "sv PfostenL":	// Pfostenstecker 1-reihig, links beschriftet
   case "sv JSTL":	// JST-Stecker
    inner+="<td colspan=2>";	// Platzhalter
   case "sv PfostenR":	// Pfostenstecker 1-reihig, rechts beschriftet
   case "sv JSTR":	// JST-Stecker
    var h=H*2*lis.length;
    inner+="<td style='padding:0' rowspan="+(lis.length+2)+">";
    var jst = sv.className.indexOf("JST")>=0;
    var xl=H-4, yo=12, more="width='8' height='8' fill='gold'";
    if (jst) {
     inner+="<svg width=30 height="+(h+8)+">\n";
     inner+="<path d='M0,"+(h/2-7)+"V5H30V"+(h+6)+"H0V"+(h/2+17)+"' fill='none' stroke-width='3' stroke='black'/>";
     xl=10; yo=15; more="width='7' height='7'";
    }else{
     inner+="<svg width="+H*2+" height="+(h+8)+">\n";
     inner+="<rect x='0' y='3' width='"+H*2+"' height='"+h+"'/>\n";
    }
    for (var j=0;j<lis.length;j++) {
     if (lis[j].getAttribute("omit")===null)
     inner+="<rect x='"+xl+"' y='"+(H*2*j+yo)+"' "+more+"/>\n";
    }
    inner+="</svg>";
    if (sv.className.endsWith("R")) inner+="<td colspan=2>";
    for (var n=0,k=sv.start;n<lis.length;n++,k+=sv.reversed?-1:1) {
     inner+="<tr height=13>";
     if (sv.className.endsWith("R")) {
      inner+="<td class=nr>"+k;
      inner+="<td class=tr>"+lis[n].innerHTML;
     }else{
      inner+="<td class=tl>"+lis[n].innerHTML;
      inner+="<td class=nl>"+k;
     }
    }
    inner+="<tr height=4><td colspan=2>";
   break;
   
   case "sv DIP":	// DIL-Schaltkreis (schmal)
   case "sv Wanne":	// Wannenstecker
   case "sv Pfosten":	// Pfostenstecker 2-reihig
   case "sv Direkt":	// Direktstecker (Platinenkante)
    console && console.assert(lis.length%2==0,"Listenlänge sollte gerade sein!");
    inner+="<td colspan=2>";	// Platzhalter
    inner+="<td style='padding:0' rowspan="+((lis.length+1>>1)+2)+">";
    var h=H*2*(lis.length+1>>1);
    var xl,xr,yo=12,elname="rect",more="";
    switch (sv.className) {
     case "sv DIP":
     inner+="<svg width=70 height="+(h+8)+">\n";
     inner+="<path d='M5,4H28A7,7 0 0 0 42,4H65V"+(h+6)+"H5Z' fill='gray' stroke-width='1' stroke='black'/>\n";
     inner+="<circle cx='16' cy='15' r='5'/>\n";
     xl=1; xr=65; more="width='4' height='13' fill='white' stroke-width='1' stroke='black'";
     break;
     case "sv Wanne":
     inner+="<svg width=60 height="+(h+12)+">\n";
     inner+="<rect x='2' y='6' width='56' height='"+(h+4)+"' fill='gray'/>\n";
     inner+="<path d='M3,"+(h/2-10)+"V5H57V"+(h+8)+"H3V"+(h/2+24)+"' fill='none' stroke-width='6' stroke='black'/>\n";
     xl=13; xr=39; xo=15; more="width='8' height='8' fill='gold'";
     break;
     case "sv Pfosten":
     inner+="<svg width="+H*4+" height="+(h+8)+">\n";
     inner+="<rect x='0' y='4' width='"+H*4+"' height='"+h+"'/>\n";
     xl=H-4; xr=H*3-4; yo=13; more="width='8' height='8' fill='gold'";
     break;
     case "sv Direkt":
     inner+="<svg width=30 height="+h+">\n";
     inner+="<rect x='10' y='5' width='10' height='"+h+"' fill='green'/>\n";
     xl=7; xr=20; yo=10; more="width='3' height='13' fill='gold'";
     break;
    }
    for (var j=0;j<lis.length;j++) {
     var x = j&1 ? xr : xl;
     var y = H*2*(j>>1)+yo;
     if (lis[j].getAttribute("omit")===null)
       inner+="<"+elname+" x='"+x+"' y='"+y+"' "+more+"/>\n";
    }
    inner+="</svg><td colspan=2>\n";
    for (var r=0;r<lis.length/2;r++) {
     inner+="<tr height=13>";
     var n=2*r; if (sv.className=="sv DIP") n=r;
     inner+="<td class=tl>"+lis[n].innerHTML;
     inner+="<td class=nl>"+(n+1);
     n=2*r+1; if (sv.className=="sv DIP") n=lis.length-1-r;
     inner+="<td class=nr>"+(n+1);
     inner+="<td class=tr>"+lis[n].innerHTML+"\n";
    }
    inner+="<tr height=4><td colspan=2><td colspan=2>\n";
   break;
  }
  table.innerHTML=inner;
  sv.parentNode.replaceChild(table,sv);
 }
// <img> in <object> umwandeln, für Vektorgrafik. Im Falle von XSLT-generierter Vektorgrafik in <iframe>.
 function img_object(img){
  var iframe=img.src.match(/as=SVG$/);	// XSLT-Prozessor am Werk
  if (img.target) img=img.target;	// im Fall von onerror
  var p=createEl(iframe?"iframe":"object");
  p.addEventListener("load",function(e){		// wirkungslos bei Chrome und XSLT: Bild bleibt zu klein.
   var svgDoc=iframe ? p.contentWindow.document : p.contentDocument;
// manchmal kommt da (bei object svg) trotzdem NULL!! Unklar warum.
   if (svgDoc) {
    var svg=svgDoc.querySelector("svg");
    var w=svg&&svg.getAttribute("width")||"640px";
    var h=svg&&svg.getAttribute("height")||"360px";
    p.setAttribute("style","width:"+w+";height:"+h+";border-width:0;");
    if (iframe) p.setAttribute("scrolling","no");	// keine inneren Rollbalken (nur Chrome, Edge)
// Chrome, Edge machen um <svg> ein <body> mit 8 Pixel Margin rundherum
    var body=svgDoc.querySelector("body");
    if (body) body.setAttribute("style","margin:0");
//   makeSizeable(p.parentNode);
   }else{
    p.removeAttribute("width");
    p.removeAttribute("height");
    console.log("Kein contentWindow.document oder contentDocument für Element: ",p);
   }
  });
  
  var src=new URL(img.src);	// der kommt hier als komplette URL an!
  src=src.pathname;		// „relativieren“
  if (src.match(/\.[we]mf$/i)) {
   if (src.match(/\.zip\//)) src+="?as=SVG";	// viewzip.php braucht (zurzeit) diesen Suffix.
   else{			// Meistens habe ich's in die .htm-Dateien so 'reingeschrieben;
    const r=getRoot()+'/';	// URL::pathname schneidet das wieder ab, das landet bei URL::search.
    src=r+"wmf2svg.php/"+src.substring(r.length);
   }
  }
  p.setAttribute(iframe?"src":"data",src);
  p.className=img.className;
  if (img.id) p.setAttribute("id",img.id);
  p.setAttribute("type","image/svg+xml");
  p.setAttribute("width",640);	// Anfängliche Größe 16:9, wird von onload() überschrieben
  p.setAttribute("height",360);
  p.appendChild(document.createTextNode(_tr("nosvg")));
  img.parentNode.replaceChild(p,img);
//  p.parentNode.className="sizeable";
  return p;
 }
// Veraltet, X3D gehört auf den Müllhaufen (zumindest als Export aus CAD-Programmen), die Zukunft gehört iSTL
 function img_x3d(img) {
  var url="/x3dview.htm?"+img.src;
  var p=createEl("iframe",{src:url,width:500,height:500,scrolling:"no",style:"border:1px solid rgba(0,255,255,0.2);background:rgba(0,255,255,0.2)"});
  img.parentNode.replaceChild(p,img);
  return p;
 }
// (Versuch der) browserseitigen Konvertierung von WMF- und 2D-Eagle-Dateien
 function img_svg(img) {
  var src=new URL(img.src);	// der kommt hier als komplette URL an!
  src=src.pathname;		// „relativieren“
  if (src.match(/\.wmf$/i)) {
   let obj;
   import(getRoot()+"/wmf2svg.js")
   .then(function(o) {obj=o; return fetch(src);})
   .then(function(r) {return r.blob();})
   .then(function(b) {return b.arrayBuffer();})
   .then(function(a) {img.parentNode.replaceChild(obj.wmf2svg(a),img);})
   .catch(function(e) {console.log(e);});
  }
 }
 function eagle_svg(img) {
  var src=new URL(img.src);	// der kommt hier als komplette URL an!
  src=src.pathname;		// „relativieren“
  if (src.match(/\.(sch|brd|lbr)/i)) {
   let obj;
   import(getRoot()+"/eagle2svg.js")
   .then(function(o) {obj=o; return fetch(src);})
   .then(function(r) {return r.text();})
   .then(function(t) {
    const parser=new DOMParser();
    const xml=parser.parseFromString(t,"text/xml");
    img.parentNode.replaceChild(obj.eagle2svg(xml),img)
   })
   .then(function(e) {;})
   .catch(function(e) {console.log(e);});
  }
 }
 function img_object_svg_all() {	// Hier keine neuen Javascript-Features!
//  var imgs=document.getElementsByTagName("img");	// Das liefert eine "live node list"!! Blöd, da diese verändert wird.
  var imgs=document.querySelectorAll("img");		// querySelectorAll liegt als Polyfill vor.
//  console.log(imgs);
  for (var i=0; i<imgs.length; i++) {
   var img=imgs[i];
   if (!img.parentNode) throw "Cannot handle IMG without parentNode";
   if (img.className.match(/^tn$/)) continue;	// Thumbnail-SVGs nicht konvertieren
   if (img.src.match(/svg$/i)) img_object(img);	// Für Edge vorauseilende Korrektur (zu spät für onerror)
   else if (img.src.match(/(stl|wrl)$/i)) img_canvas(img);
   else img.onerror=onimgerror;
  }
 }
// <img> in <div> umwandeln, für STL-Dateien
// MUSS PARENTNODE HABEN!!
 function img_canvas(img){
  var pn=img.parentNode;
  if (!pn) {
   console.error("Keine ParentNode!!");
   return;
  }
  var id=img.id||"BR"+Math.floor((Math.random()*10000));
  var p=createEl("div",{id:id,"class":"sizeable stl",tabindex:1});
  var url=img.src;	// sollte auf .stl enden
  pn.replaceChild(p,img);	// schon mal ersetzen
  makeSizeable(p);
  if (window.stlview) g_stlviews.set(pn,stlview(p,url));	// Wenn bereits geladen, sofort ausführen
  else{
   if (!g_stlloads[0]) {	// JavaScript nur 1× laden
    var js=createEl("script",{type:"text/javascript",src:getRoot()+"/stlview.js"});
    js.onload=function(){
     g_stlloads.forEach(function(l){g_stlviews.set(l.pn,stlview(l.p,l.url))});
     g_stlloads=undefined;
    }	// verzögert ausführen
    document.head.appendChild(js);	// JavaScript laden
   }
   g_stlloads.push({pn:pn,p:p,url:url});
  }
 }
 function onimgerror(el) {
  if (el.target) el=el.target;
  if (!el.parentNode) {
   console.log("Cannot handle "+el.nodeName+" without parentNode");
   return;
  }
  if (el.src.match(/\.[we]mf$/i)) return img_svg(el);	// in direkt eingebettetes SVG wandeln
  if (el.src.match(/\.(sch|brd|lbr)(|\?.*)$/i)) return eagle_svg(el);
  if (el.src.match(/(svg$|[we]mf)/i)) return img_object(el);
  if (el.src.match(/([if]?stl|wrl)$/i)) return img_canvas(el);
  if (el.src.match(/\.x3d$/i)) return img_x3d(el);
  console.log("Ladefehler: ",el);
// TODO: Ladefehler per Mail an mich petzen
 }
// <object>/<iframe> zurück in <img> umwandeln, für Pixelgrafik
 function object_img(obj,url) {
  var p=createEl("img");
  if (obj.id) p.setAttribute("id",obj.id);
  obj.parentNode.replaceChild(p,obj);
  p.onerror=onimgerror;
  p.src=url;
  return p;
 }
